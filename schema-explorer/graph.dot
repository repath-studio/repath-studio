  "Element" [label="{Element|:id [:ref \"ElementId\"]\l:tag [:ref \"ElementTag\"]\l:label string?\l:parent [:ref \"ElementId\"]\l:type [:= :element]\l:visible boolean?\l:locked boolean?\l:selected boolean?\l:selected-handles [:set keyword?]\l:children [:vector [:ref \"ElementId\"]]\l:bbox [:ref \"BBox\"]\l:content string?\l:attrs [:ref \"ElementAttrs\"]\l}", fillcolor="#fff0cd"]
