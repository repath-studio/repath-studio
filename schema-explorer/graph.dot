  "App" [label="{App|:tool [:ref \"Tool\"]\l:cached-tool [:ref \"Tool\"]\l:active-pointers [:map-of [:ref \"PointerId\"] [:ref \"PointerEvent\"]]\l:pointer-pos [:ref \"Vec2\"]\l:last-origin [:ref \"Vec2\"]\l:pointer-offset [:ref \"Vec2\"]\l:adjusted-pointer-pos [:ref \"Vec2\"]\l:adjusted-pointer-offset [:ref \"Vec2\"]\l:nearest-neighbor-offset [:maybe [:ref \"Vec2\"]]\l:nearest-neighbor [:maybe [:ref \"NearestNeighbor\"]]\l:nearest-neighbors [:sequential [:ref \"NearestNeighbor\"]]\l:drag-pointer number?\l:pinch-distance number?\l:pinch-midpoint [:ref \"Vec2\"]\l:zoom-sensitivity [:and number? [:\>= 0.01] [:\<= 0.99]]\l:event-timestamp number?\l:features [:set [:ref \"Feature\"]]\l:double-click-delta [:and number? pos?]\l:state [:ref \"State\"]\l:cached-state [:ref \"State\"]\l:grid boolean?\l:rulers boolean?\l:guides boolean?\l:guides-locked boolean?\l:snap [:ref \"Snap\"]\l:active-document [:maybe [:ref \"DocumentId\"]]\l:cursor [:ref \"Cursor\"]\l:dom-rect [:ref \"DomRect\"]\l:dialogs [:vector [:ref \"Dialog\"]]\l:documents [:map-of [:ref \"DocumentId\"] [:ref \"Document\"]]\l:document-tabs [:vector [:ref \"DocumentId\"]]\l:recent [:vector [:ref \"RecentDocument\"]]\l:drag-threshold number?\l:system-fonts [:ref \"SystemFonts\"]\l:debug-info boolean?\l:help-bar boolean?\l:loading boolean?\l:pen-mode boolean?\l:backdrop boolean?\l:user-lang [:ref \"LanguageId\"]\l:system-lang [:ref \"LanguageCodeIdentifier\"]\l:languages [:ref \"LanguageRegistry\"]\l:icons [:ref \"Icons\"]\l:platform [:ref \"Platform\"]\l:versions [:maybe map?]\l:env [:maybe map?]\l:standalone boolean?\l:menubar [:ref \"Menubar\"]\l:install-prompt [:ref \"JS_Object\"]\l:user-agent string?\l:shell [:ref \"Shell\"]\l:error-reporting boolean?\l:worker App$Worker\l:window [:ref \"Window\"]\l:theme [:ref \"Theme\"]\l:timeline [:ref \"Timeline\"]\l:panels [:map-of [:ref \"PanelId\"] [:ref \"Panel\"]]\l:version string?\l:fx vector?\l:pivot-point [:ref \"Vec2\"]\l:anchor-point [:ref \"Vec2\"]\l:anchor-offset [:ref \"Vec2\"]\l:select-box [:maybe [:ref \"Element\"]]\l:clicked-element [:or [:ref \"Element\"] [:ref \"Handle\"]]\l:clipboard App$Clipboard\l:kdtree [:maybe map?]\l:viewbox-kdtree [:maybe map?]\l:actions [:ref \"ActionRegistry\"]\l:action-groups [:ref \"ActionGroupRegistry\"]\l:a11y [:ref \"A11y\"]\l:re-pressed.core/keydown map?\l}", fillcolor="#fff0cd"]
